{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BidTracker",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "job_id": { "type": "string" },
    "job_title": { "type": "string" },
    "job_url": { "type": "string" },
    "package_id": { "type": "string" },
    "state": { "type": "string" },
    "connects_cost": { "type": ["integer", "null"] },
    "connects_spent": { "type": "integer" },
    "reason": { "type": "string" },
    "source_session": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "required": [
    "id",
    "run_id",
    "job_id",
    "job_title",
    "job_url",
    "package_id",
    "state",
    "connects_cost",
    "connects_spent",
    "reason",
    "source_session",
    "updated_at"
  ]
}
