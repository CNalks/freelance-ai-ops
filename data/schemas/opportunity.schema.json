{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Opportunity",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "source": { "type": "string" },
    "job_url": { "type": "string" },
    "title": { "type": "string" },
    "category": { "type": "string" },
    "budget_type": { "type": "string" },
    "budget": { "type": ["string", "number", "null"] },
    "posted_at_text": { "type": "string" },
    "proposal_count_text": { "type": "string" },
    "client_country": { "type": "string" },
    "client_spend_text": { "type": "string" },
    "payment_verified": { "type": "boolean" },
    "description_excerpt": { "type": "string" },
    "skills": { "type": "array", "items": { "type": "string" } },
    "fit_score": { "type": "number" },
    "client_quality_score": { "type": "number" },
    "competition_score": { "type": "number" },
    "scope_clarity_score": { "type": "number" },
    "risk_score": { "type": "number" },
    "connects_cost": { "type": ["integer", "null"] },
    "expected_value_band": { "type": "string" },
    "recommended_action": { "type": "string" },
    "decision_reason": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "required": [
    "id",
    "source",
    "job_url",
    "title",
    "category",
    "budget_type",
    "budget",
    "posted_at_text",
    "proposal_count_text",
    "client_country",
    "client_spend_text",
    "payment_verified",
    "description_excerpt",
    "skills",
    "fit_score",
    "client_quality_score",
    "competition_score",
    "scope_clarity_score",
    "risk_score",
    "connects_cost",
    "expected_value_band",
    "recommended_action",
    "decision_reason",
    "created_at"
  ]
}
